{
  "name": "audioforge",
  "version": "1.1.0",
  "description": "🔊 AI Audio Generator CLI - Multi-provider sound effects & music generation from your terminal",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "audioforge": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build",
    "postbuild": "chmod +x dist/index.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "audio",
    "sound-effects",
    "music",
    "cli",
    "generator",
    "elevenlabs",
    "stable-audio",
    "game-audio",
    "sfx"
  ],
  "author": "magicpro97",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicpro97/audioforge.git"
  },
  "homepage": "https://github.com/magicpro97/audioforge#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@magicpro97/forge-core": "^1.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.1.1",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
